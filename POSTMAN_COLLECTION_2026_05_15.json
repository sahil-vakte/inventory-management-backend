{
	"info": {
		"_postman_id": "order-item-features-2026-05-15",
		"name": "Inventory — Order Item Features (May 15, 2026)",
		"description": "New endpoints added on May 15, 2026:\n1. GET  /api/v1/orders/statuses/               — All status reference data\n2. PATCH /api/v1/order-items/{id}/assign/       — Assign/unassign employee to a line item\n3. PATCH /api/v1/order-items/{id}/update-status/ — Update processing status of a line item\n4. GET  /api/v1/orders/                         — Now includes completion_percentage, items_total, items_completed, items_assigned, items_pending\n5. GET  /api/v1/order-items/{id}/               — Now includes assigned_to, processing_status, quantity_processed\n\nEnvironment variables required:\n  base_url     → http://localhost:8000\n  access_token → obtained from Login request",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "access_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "order_item_id",
			"value": "1",
			"type": "string"
		},
		{
			"key": "employee_user_id",
			"value": "1",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "0. Authentication",
			"item": [
				{
					"name": "Login (Get JWT Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('access_token', jsonData.access);",
									"    pm.environment.set('access_token', jsonData.access);",
									"    pm.environment.set('refresh_token', jsonData.refresh);",
									"    console.log('Access token saved');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/login/",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "login", ""]
						},
						"description": "Obtain a JWT access token. The test script automatically saves it to `access_token` collection and environment variable."
					},
					"response": [
						{
							"name": "200 OK",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"access\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"refresh\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n}"
						}
					]
				}
			]
		},
		{
			"name": "1. Status Reference",
			"item": [
				{
					"name": "GET All Order & Item Statuses",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/orders/statuses/",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "orders", "statuses", ""]
						},
						"description": "Returns all status choices for orders and order items. No authentication required — use this to populate dropdowns in the UI.\n\nReturns four groups:\n- order_statuses\n- payment_statuses\n- order_sources\n- item_processing_statuses"
					},
					"response": [
						{
							"name": "200 OK",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"order_statuses\": [\n        { \"value\": \"PENDING\",    \"label\": \"Pending\" },\n        { \"value\": \"CONFIRMED\",  \"label\": \"Confirmed\" },\n        { \"value\": \"PROCESSING\", \"label\": \"Processing\" },\n        { \"value\": \"SHIPPED\",    \"label\": \"Shipped\" },\n        { \"value\": \"DELIVERED\",  \"label\": \"Delivered\" },\n        { \"value\": \"CANCELLED\",  \"label\": \"Cancelled\" },\n        { \"value\": \"ON_HOLD\",    \"label\": \"On Hold\" }\n    ],\n    \"payment_statuses\": [\n        { \"value\": \"UNPAID\",    \"label\": \"Unpaid\" },\n        { \"value\": \"PARTIAL\",   \"label\": \"Partially Paid\" },\n        { \"value\": \"PAID\",      \"label\": \"Paid\" },\n        { \"value\": \"REFUNDED\",  \"label\": \"Refunded\" },\n        { \"value\": \"FAILED\",    \"label\": \"Failed\" }\n    ],\n    \"order_sources\": [\n        { \"value\": \"MANUAL\",  \"label\": \"Manual Entry\" },\n        { \"value\": \"XML\",     \"label\": \"XML Import\" },\n        { \"value\": \"EBAY\",    \"label\": \"eBay\" },\n        { \"value\": \"API\",     \"label\": \"API\" },\n        { \"value\": \"WEBSITE\", \"label\": \"Website\" }\n    ],\n    \"item_processing_statuses\": [\n        { \"value\": \"PENDING\",     \"label\": \"Pending\" },\n        { \"value\": \"IN_PROGRESS\", \"label\": \"In Progress\" },\n        { \"value\": \"PICKED\",      \"label\": \"Picked\" },\n        { \"value\": \"EXCEPTION\",   \"label\": \"Exception\" },\n        { \"value\": \"COMPLETED\",   \"label\": \"Completed\" }\n    ]\n}"
						}
					]
				}
			]
		},
		{
			"name": "2. Order Item — Assign Employee",
			"item": [
				{
					"name": "PATCH Assign Employee to Item",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"assigned_to\": {{employee_user_id}}\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/order-items/{{order_item_id}}/assign/",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "order-items", "{{order_item_id}}", "assign", ""]
						},
						"description": "Assign an employee (by user id) to a specific order line item.\n\nField:\n- `assigned_to` (integer) — the user id of the employee to assign\n\nTo unassign, send `null` instead."
					},
					"response": [
						{
							"name": "200 OK — Assigned",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"id\": 1,\n    \"sku\": \"109LT-BLK-001\",\n    \"order_number\": \"ORD-20260503-0001\",\n    \"assigned_to\": 1,\n    \"assigned_to_username\": \"john.smith\",\n    \"assigned_to_full_name\": \"John Smith\",\n    \"message\": \"Item assigned to john.smith\"\n}"
						},
						{
							"name": "400 Bad Request — User not found",
							"status": "Bad Request",
							"code": 400,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"error\": \"User with id 99 does not exist\"\n}"
						},
						{
							"name": "401 Unauthorized",
							"status": "Unauthorized",
							"code": 401,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"detail\": \"Authentication credentials were not provided.\"\n}"
						}
					]
				},
				{
					"name": "PATCH Unassign Employee from Item",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"assigned_to\": null\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/order-items/{{order_item_id}}/assign/",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "order-items", "{{order_item_id}}", "assign", ""]
						},
						"description": "Remove employee assignment from an order line item by sending `null`."
					},
					"response": [
						{
							"name": "200 OK — Unassigned",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"id\": 1,\n    \"sku\": \"109LT-BLK-001\",\n    \"order_number\": \"ORD-20260503-0001\",\n    \"assigned_to\": null,\n    \"assigned_to_username\": null,\n    \"message\": \"Item unassigned successfully\"\n}"
						}
					]
				}
			]
		},
		{
			"name": "3. Order Item — Update Status",
			"item": [
				{
					"name": "PATCH Update Item Status — PENDING",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"processing_status\": \"PENDING\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/order-items/{{order_item_id}}/update-status/",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "order-items", "{{order_item_id}}", "update-status", ""]
						},
						"description": "Update the processing status of a line item. Optionally also update quantity_processed.\n\nValid values for `processing_status`:\n- PENDING\n- IN_PROGRESS\n- PICKED\n- EXCEPTION\n- COMPLETED\n\n`quantity_processed` is optional — must be between 0 and the item's total quantity."
					},
					"response": []
				},
				{
					"name": "PATCH Update Item Status — IN_PROGRESS",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"processing_status\": \"IN_PROGRESS\",\n    \"quantity_processed\": 2\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/order-items/{{order_item_id}}/update-status/",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "order-items", "{{order_item_id}}", "update-status", ""]
						},
						"description": "Mark item as in progress. Optionally set quantity_processed."
					},
					"response": []
				},
				{
					"name": "PATCH Update Item Status — PICKED (with quantity)",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"processing_status\": \"PICKED\",\n    \"quantity_processed\": 5\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/order-items/{{order_item_id}}/update-status/",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "order-items", "{{order_item_id}}", "update-status", ""]
						},
						"description": "Mark item as fully picked. quantity_processed should equal total quantity."
					},
					"response": [
						{
							"name": "200 OK",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"id\": 1,\n    \"sku\": \"109LT-BLK-001\",\n    \"order_number\": \"ORD-20260503-0001\",\n    \"previous_status\": \"IN_PROGRESS\",\n    \"processing_status\": \"PICKED\",\n    \"processing_status_display\": \"Picked\",\n    \"quantity\": 5,\n    \"quantity_processed\": 5,\n    \"completion_pct\": 100\n}"
						}
					]
				},
				{
					"name": "PATCH Update Item Status — EXCEPTION",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"processing_status\": \"EXCEPTION\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/order-items/{{order_item_id}}/update-status/",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "order-items", "{{order_item_id}}", "update-status", ""]
						},
						"description": "Flag item as having an exception (e.g. out of stock, damaged)."
					},
					"response": []
				},
				{
					"name": "PATCH Update Item Status — COMPLETED",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"processing_status\": \"COMPLETED\",\n    \"quantity_processed\": 5\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/order-items/{{order_item_id}}/update-status/",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "order-items", "{{order_item_id}}", "update-status", ""]
						},
						"description": "Mark item as fully completed."
					},
					"response": []
				},
				{
					"name": "PATCH Update Item Status — Invalid (400)",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"processing_status\": \"DONE\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/order-items/{{order_item_id}}/update-status/",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "order-items", "{{order_item_id}}", "update-status", ""]
						},
						"description": "Example of an invalid status — will return 400 with valid_statuses list."
					},
					"response": [
						{
							"name": "400 Bad Request — Invalid status",
							"status": "Bad Request",
							"code": 400,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"error\": \"Invalid status \\\"DONE\\\"\",\n    \"valid_statuses\": [\"PENDING\", \"IN_PROGRESS\", \"PICKED\", \"EXCEPTION\", \"COMPLETED\"]\n}"
						}
					]
				},
				{
					"name": "PATCH Update Item Status — quantity_processed too high (400)",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"processing_status\": \"PICKED\",\n    \"quantity_processed\": 999\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/order-items/{{order_item_id}}/update-status/",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "order-items", "{{order_item_id}}", "update-status", ""]
						},
						"description": "Example of quantity_processed exceeding item quantity — will return 400."
					},
					"response": [
						{
							"name": "400 Bad Request — quantity too high",
							"status": "Bad Request",
							"code": 400,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"error\": \"quantity_processed must be between 0 and 5\"\n}"
						}
					]
				}
			]
		},
		{
			"name": "4. Orders List — Progress Bar Data",
			"item": [
				{
					"name": "GET All Orders (with progress fields)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/orders/",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "orders", ""]
						},
						"description": "List all orders. Response now includes progress bar fields for each order:\n\n- `completion_percentage` — 0–100, based on items in PICKED or COMPLETED status\n- `items_total` — total number of line items\n- `items_completed` — items in PICKED or COMPLETED\n- `items_assigned` — items with an employee assigned\n- `items_pending` — items still in PENDING"
					},
					"response": [
						{
							"name": "200 OK",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"count\": 1,\n    \"next\": null,\n    \"previous\": null,\n    \"results\": [\n        {\n            \"id\": 1,\n            \"order_number\": \"ORD-20260503-0001\",\n            \"external_order_id\": null,\n            \"customer_name\": \"Jane Doe\",\n            \"customer_email\": \"jane@example.com\",\n            \"order_status\": \"PROCESSING\",\n            \"order_status_display\": \"Processing\",\n            \"payment_status\": \"PAID\",\n            \"payment_status_display\": \"Paid\",\n            \"order_date\": \"2026-05-03T09:00:00Z\",\n            \"total_amount\": \"125.00\",\n            \"item_count\": 3,\n            \"total_quantity\": 8,\n            \"created_by_username\": \"admin\",\n            \"assigned_to\": 2,\n            \"assigned_to_username\": \"admin\",\n            \"order_source\": \"WEBSITE\",\n            \"created_at\": \"2026-05-03T09:00:00Z\",\n            \"completion_percentage\": 67,\n            \"items_total\": 3,\n            \"items_completed\": 2,\n            \"items_assigned\": 3,\n            \"items_pending\": 1\n        }\n    ]\n}"
						}
					]
				},
				{
					"name": "GET Orders — Filter by order_status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/orders/?order_status=PROCESSING",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "orders", ""],
							"query": [
								{ "key": "order_status", "value": "PROCESSING" }
							]
						},
						"description": "Filter orders by status. Valid values: PENDING, CONFIRMED, PROCESSING, SHIPPED, DELIVERED, CANCELLED, ON_HOLD"
					},
					"response": []
				}
			]
		},
		{
			"name": "5. Order Item — Detail",
			"item": [
				{
					"name": "GET Order Item by ID (with new fields)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/order-items/{{order_item_id}}/",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "order-items", "{{order_item_id}}", ""]
						},
						"description": "Retrieve a single order item. Response now includes:\n\n- `assigned_to` — user id of assigned employee (or null)\n- `assigned_to_username` — username of assigned employee\n- `processing_status` — current item status value\n- `processing_status_display` — human-readable label\n- `quantity_processed` — how many units have been processed so far\n- `quantity_ordered` — original quantity at time of order"
					},
					"response": [
						{
							"name": "200 OK",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"id\": 1,\n    \"order\": 1,\n    \"stock_item\": 3,\n    \"stock_detail\": {\n        \"id\": 3,\n        \"sku\": \"109LT-BLK-001\"\n    },\n    \"sku\": \"109LT-BLK-001\",\n    \"product_name\": \"109LT Black Roll\",\n    \"product_type\": \"109LT\",\n    \"color_code\": \"BLK\",\n    \"quantity\": 5,\n    \"quantity_ordered\": 5,\n    \"quantity_processed\": 3,\n    \"unit_price\": \"12.50\",\n    \"line_total\": \"62.50\",\n    \"tax_rate\": \"20.00\",\n    \"discount_amount\": \"0.00\",\n    \"assigned_to\": 1,\n    \"assigned_to_username\": \"john.smith\",\n    \"processing_status\": \"IN_PROGRESS\",\n    \"processing_status_display\": \"In Progress\",\n    \"notes\": null,\n    \"created_at\": \"2026-05-03T09:00:00Z\",\n    \"updated_at\": \"2026-05-15T10:30:00Z\"\n}"
						}
					]
				},
				{
					"name": "GET Order Items — Filter by processing_status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/order-items/?processing_status=PENDING",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "order-items", ""],
							"query": [
								{ "key": "processing_status", "value": "PENDING" }
							]
						},
						"description": "Filter order items by processing status. Valid values: PENDING, IN_PROGRESS, PICKED, EXCEPTION, COMPLETED"
					},
					"response": []
				},
				{
					"name": "GET Order Items — Filter by assigned_to",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/order-items/?assigned_to={{employee_user_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "order-items", ""],
							"query": [
								{ "key": "assigned_to", "value": "{{employee_user_id}}" }
							]
						},
						"description": "Get all order items assigned to a specific employee (by user id)."
					},
					"response": []
				}
			]
		}
	]
}
